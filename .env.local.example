# HighWise — environment variable template
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# ── Supabase (added in v0.3) ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=

# Anon / publishable key — safe to expose to the browser (RLS enforces access control)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret keys — SERVER SIDE ONLY. Never expose to the browser or commit to git.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# ── PostHog analytics (existing, from v0.2) ───────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ── Feedback form (existing, from v0.2) ──────────────────────────────────────
NEXT_PUBLIC_FEEDBACK_URL=
